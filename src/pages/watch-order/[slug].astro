---
import BaseLayout from "@/layouts/BaseLayout.astro";
import AdSlot from "@/components/AdSlot.astro";
import { canonicalPath, fuzzyDateLabel, titleCase, watchOrderIndex } from "@/lib/anime";
import { watchOrderJsonLd } from "@/lib/seo";
import type { WatchOrderGuide } from "@/types/anime";

export function getStaticPaths() {
  return watchOrderIndex.items.map((guide) => ({
    params: { slug: guide.slug },
    props: { guide }
  }));
}

const { guide } = Astro.props as { guide: WatchOrderGuide };
const releaseOrder = [...guide.entries].sort((a, b) => dateRank(a.startDate) - dateRank(b.startDate));
const optionalEntries = guide.entries.filter((entry) => ["OVA", "ONA", "SPECIAL", "SPIN_OFF", "SIDE_STORY", "SUMMARY", "ALTERNATIVE"].includes(String(entry.relationType || "").toUpperCase()));
const mainPath = guide.entries.filter((entry) => ["SOURCE", "MAIN", "PREQUEL", "SEQUEL"].includes(String(entry.relationType || "").toUpperCase()));

function dateRank(date: WatchOrderGuide["entries"][number]["startDate"]) {
  if (!date?.year) return Number.MAX_SAFE_INTEGER;
  return Number(`${date.year}${String(date.month || 1).padStart(2, "0")}${String(date.day || 1).padStart(2, "0")}`);
}
---

<BaseLayout
  title={guide.title}
  description={guide.description}
  canonical={canonicalPath(`/watch-order/${guide.slug}/`)}
  structuredData={watchOrderJsonLd(guide)}
>
  <section class="section">
    <div class="section-header">
      <div>
        <p class="eyebrow">Suggested viewing order</p>
        <h1>{guide.title}</h1>
        <p>{guide.description} Use the labels as a franchise map, not a replacement for official release information.</p>
      </div>
      <a class="button primary" href="/watch-order/">All guides</a>
    </div>
  </section>

  <section class="section">
    <div class="editor-note">
      <p class="eyebrow">Recommended order</p>
      <h2>Start here</h2>
      <p>
        Follow the main path first, then add side stories, OVAs, specials, and recap movies
        after the closest related season. This keeps the story readable without losing the
        extra franchise material.
      </p>
      <div class="chip-grid">
        {mainPath.slice(0, 8).map((entry, index) => (
          <a href={`/anime/${entry.slug}/`}><span>{index + 1}</span>{entry.title}</a>
        ))}
      </div>
    </div>
  </section>

  <section class="section timeline-list">
    {guide.entries.map((entry, index) => (
      <article class="timeline-item">
        <span class="timeline-rank">{index + 1}</span>
        <img src={entry.coverImage || "/og-default.svg"} alt="" loading="lazy" referrerpolicy="no-referrer" />
        <div>
          <p class="eyebrow">{titleCase(entry.relationType || "Related")}</p>
          <h2><a href={`/anime/${entry.slug}/`}>{entry.title}</a></h2>
          <p>{titleCase(entry.format || "Anime")} · {fuzzyDateLabel(entry.startDate)} · {entry.episodes ? `${entry.episodes} episodes` : "Episodes TBA"}</p>
        </div>
      </article>
    ))}
  </section>

  <section class="section split-feature">
    <div class="editor-note">
      <p class="eyebrow">Release order</p>
      <h2>Original release path</h2>
      <p>Use this if you prefer to watch the franchise as audiences encountered it over time.</p>
      <div class="link-stack">
        {releaseOrder.slice(0, 10).map((entry) => (
          <a href={`/anime/${entry.slug}/`}>{fuzzyDateLabel(entry.startDate)} · {entry.title}</a>
        ))}
      </div>
    </div>
    <div class="editor-note">
      <p class="eyebrow">Skip and OVA notes</p>
      <h2>Optional material</h2>
      <p>
        Recap movies and alternative versions are usually optional if you already watched
        the corresponding TV season. OVAs, specials, side stories, and spin-offs are best
        treated as bonus material unless they are labeled prequel or sequel.
      </p>
      <div class="link-stack">
        {(optionalEntries.length ? optionalEntries : guide.entries.slice(0, 4)).slice(0, 8).map((entry) => (
          <a href={`/anime/${entry.slug}/`}>{titleCase(entry.relationType || "Related")} · {entry.title}</a>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="keyword-panel">
      <p class="eyebrow">Watch order FAQ</p>
      <h2>{guide.title} questions</h2>
      <div class="faq-grid">
        <article>
          <h3>What is the best order?</h3>
          <p>Use the recommended order above for story flow, then check the release order if you want the original broadcast context.</p>
        </article>
        <article>
          <h3>Can I skip recap movies?</h3>
          <p>Usually yes. Entries labeled alternative or summary are often safer to save for later unless you want a refresher.</p>
        </article>
        <article>
          <h3>Are OVAs and specials required?</h3>
          <p>Most are optional side material. Watch them after the season or movie they are closest to in the list.</p>
        </article>
        <article>
          <h3>Does Airing Atlas stream anime?</h3>
          <p>No. This page is a franchise map and links back to legal research pages where official links are available.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section">
    <AdSlot />
  </section>
</BaseLayout>
