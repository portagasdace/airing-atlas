---
import BaseLayout from "@/layouts/BaseLayout.astro";
import AnimeCard from "@/components/AnimeCard.astro";
import AiringRow from "@/components/AiringRow.astro";
import AdSlot from "@/components/AdSlot.astro";
import { allAiringEntries, allAnime, animeById, animeByRanking, animeCatalog, canonicalPath, formatNumber, genreIndex, watchOrderIndex } from "@/lib/anime";
import { discoveryClusters } from "@/lib/discovery-clusters";
import { qualityWatchOrderFor, qualityWatchOrderGuides } from "@/lib/manual-content";
import { futureAiringEntries, isQualityNextEpisodeAnime, publicNextEpisodeAnime } from "@/lib/quality";
import { animeLikeSlug, nextEpisodeSlug } from "@/lib/search-intents";
import { websiteJsonLd } from "@/lib/seo";

const upcoming = futureAiringEntries(allAiringEntries).slice(0, 5);
const publicNextEpisodes = publicNextEpisodeAnime(allAnime).slice(0, 4);
const trending = animeByRanking("trending").slice(0, 6);
const topAiring = animeByRanking("current").slice(0, 3);
const topGenres = genreIndex.items.slice(0, 6);
const featuredClusters = discoveryClusters.slice(0, 4);
const watchGuides = qualityWatchOrderGuides(watchOrderIndex.items).slice(0, 4);
const jujutsuGuide = qualityWatchOrderFor(113415) || watchGuides[0];
const attackOnTitan = animeById(16498);
const demonSlayer = animeById(101922);
const onePiece = animeById(21);
const keywordPaths = [
  { label: "anime airing schedule", href: "/calendar/", intent: "Calendar" },
  { label: "anime next episode schedule", href: "/next-episode/", intent: "Next episode" },
  { label: "anime watch order", href: "/watch-order/", intent: "Watch order" },
  attackOnTitan && { label: "anime like Attack on Titan", href: `/anime-like/${animeLikeSlug(attackOnTitan)}/`, intent: "Similar guide" },
  demonSlayer && { label: "anime like Demon Slayer", href: `/anime-like/${animeLikeSlug(demonSlayer)}/`, intent: "Similar guide" },
  jujutsuGuide && { label: "Jujutsu Kaisen watch order", href: `/watch-order/${jujutsuGuide.slug}/`, intent: "Watch order" },
  onePiece && isQualityNextEpisodeAnime(onePiece) && { label: "One Piece next episode", href: `/next-episode/${nextEpisodeSlug(onePiece)}/`, intent: "Next episode" },
  ...featuredClusters.map((cluster) => ({
    label: cluster.title.toLowerCase(),
    href: `/discover/${cluster.slug}/`,
    intent: "Discovery"
  })),
  ...topGenres.slice(0, 3).map((genre) => ({
    label: `best ${genre.genre.toLowerCase()} anime`,
    href: `/genres/${genre.slug}/`,
    intent: "Genre"
  }))
].filter((item): item is { label: string; href: string; intent: string } => Boolean(item)).slice(0, 12);
---

<BaseLayout
  title="Anime Airing Schedule, Watch Orders & Similar Anime Finder"
  description="Track anime airing times, next episodes, watch orders, similar anime guides, seasonal rankings, and a private browser watchlist."
  canonical={canonicalPath("/")}
  structuredData={websiteJsonLd()}
>
  <section class="hero" data-track-section="home_hero">
    <div class="hero-copy">
      <p class="eyebrow">Global anime schedule</p>
      <h1>Airing Atlas</h1>
      <p class="lede">
        Anime airing schedule, next episode tracker, watch order maps, and similar anime
        guides for fans who want useful discovery without unauthorized streams.
      </p>
      <div class="hero-actions">
        <a class="button primary" href="/calendar/" data-track-event="home_primary_calendar" data-track-label="Open calendar">Open calendar</a>
        <a class="button" href="/discover/" data-track-event="home_primary_discover" data-track-label="Search catalog">Search catalog</a>
        <a class="button" href="/anime-like/" data-track-event="home_primary_anime_like" data-track-label="Anime like guides">Anime like guides</a>
      </div>
    </div>
    <div class="ticker-panel">
      <p class="eyebrow">Next episodes in your local time</p>
      <p class="freshness-note">Updated <time data-generated-at={animeCatalog.generatedAt}>{new Date(animeCatalog.generatedAt).toUTCString()}</time>.</p>
      <div class="airing-list">
        {upcoming.length ? upcoming.map((entry) => <AiringRow entry={entry} />) : <p>No future episodes are listed in the current build.</p>}
      </div>
    </div>
  </section>

  <section class="section daily-desk" aria-label="Daily anime dashboard" data-track-section="home_daily_dashboard">
    <div>
      <p class="eyebrow">Daily tool desk</p>
      <h2>Start with what changed today</h2>
      <p>
        Use the schedule first, then jump into the guides that tend to earn
        repeat visits: next episodes, watch orders, and anime-like paths.
      </p>
    </div>
    <div class="mini-list">
      {publicNextEpisodes.map((anime, index) => (
        <a href={`/next-episode/${nextEpisodeSlug(anime)}/`} data-track-event="next_episode_detail_click" data-track-label={`${anime.title.english || anime.title.romaji} next episode`} data-anime-id={anime.id} data-result-position={index + 1}>
          <span>{index + 1}</span>
          <strong>{anime.title.english || anime.title.romaji}</strong>
          <small>Next episode in local time</small>
        </a>
      ))}
    </div>
  </section>

  <section class="section quick-entry-grid" aria-label="Start with a tool" data-track-section="home_tool_grid">
    <a class="quick-entry primary-entry" href="/calendar/" data-track-event="home_tool_calendar" data-track-label="Today schedule">
      <span class="eyebrow">Today</span>
      <strong>Airing calendar</strong>
      <small>Local-time episode drops and this week&apos;s schedule.</small>
    </a>
    <a class="quick-entry" href="/next-episode/" data-track-event="home_tool_next_episode" data-track-label="Next episode hub">
      <span class="eyebrow">Updated</span>
      <strong>Next episode hub</strong>
      <small>Fresh future releases from the latest four-hour build.</small>
    </a>
    <a class="quick-entry" href="/discover/dark-fantasy-anime/" data-track-event="home_tool_discover_cluster" data-track-label="Dark fantasy anime">
      <span class="eyebrow">Popular guides</span>
      <strong>Curated discovery</strong>
      <small>Dark fantasy, battle shounen, mind games, romance drama, and more.</small>
    </a>
    <a class="quick-entry" href="/anime-like/" data-track-event="home_tool_anime_like" data-track-label="Anime like guides">
      <span class="eyebrow">Guides</span>
      <strong>Anime like X</strong>
      <small>Curated pages for Attack on Titan, Demon Slayer, Jujutsu Kaisen, and more.</small>
    </a>
    <a class="quick-entry" href="/watchlist/" data-track-event="home_tool_watchlist" data-track-label="Watchlist">
      <span class="eyebrow">Retention</span>
      <strong>Your watchlist</strong>
      <small>Browser-only next-up sorting, airing today, export, and import.</small>
    </a>
  </section>

  <section class="feature-band" aria-label="Catalog stats">
    <div class="section">
      <div class="stat-tile"><strong>{animeCatalog.season}</strong><span>current season</span></div>
      <div class="stat-tile"><strong>{animeCatalog.seasonYear}</strong><span>season year</span></div>
      <div class="stat-tile"><strong>{formatNumber(animeCatalog.anime.length)}</strong><span>indexed titles</span></div>
      <div class="stat-tile"><strong>{formatNumber(futureAiringEntries(allAiringEntries).length)}</strong><span>future episodes</span></div>
    </div>
  </section>

  <section class="section">
    <div class="keyword-panel" data-track-section="home_popular_guides">
      <p class="eyebrow">Search paths</p>
      <h2>Popular anime guides</h2>
      <p>Fast routes for long-tail searches around similar anime, release schedules, watch orders, and genre discovery.</p>
      <div class="keyword-list">
        {keywordPaths.map((item) => (
          <a href={item.href} data-track-event="related_guide_click" data-track-label={item.label}>
            <span>{item.intent}</span>
            {item.label}
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-header">
      <div>
        <p class="eyebrow">Top airing now</p>
        <h2>Current season picks</h2>
        <p>
          Built from AniList data and organized for quick decisions: score, format,
          genres, and upcoming episode timing before you add a title to your list.
        </p>
      </div>
      <a class="button" href="/calendar/">Full schedule</a>
    </div>
    <div class="anime-grid">
      {topAiring.map((anime, index) => <AnimeCard anime={anime} rank={index + 1} />)}
    </div>
  </section>

  <section class="section">
    <AdSlot />
  </section>

  <section class="section split-feature">
    <div>
      <div class="section-header">
        <div>
          <p class="eyebrow">Discovery tools</p>
          <h2>Search by mood, season, and format</h2>
          <p>
            The new discovery desk turns the catalog into a filterable tool for fans who
            know a vibe, genre, or season but not the exact title yet.
          </p>
        </div>
      </div>
      <div class="chip-grid">
        {topGenres.map((genre) => <a href={`/genres/${genre.slug}/`}>{genre.genre}<span>{genre.count}</span></a>)}
        {featuredClusters.map((cluster) => <a href={`/discover/${cluster.slug}/`}>{cluster.shortLabel}<span>guide</span></a>)}
      </div>
    </div>
    <div>
      <div class="section-header">
        <div>
          <p class="eyebrow">Franchise maps</p>
          <h2>Watch order guides</h2>
          <p>Curated franchise paths that keep anime entries separate from manga sources and recap-only pages.</p>
        </div>
      </div>
      <div class="link-stack">
        {watchGuides.map((guide) => <a href={`/watch-order/${guide.slug}/`} data-track-event="related_guide_click" data-track-label={guide.title}>{guide.title}</a>)}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-header">
      <div>
        <p class="eyebrow">Trending</p>
        <h2>Audience heat map</h2>
        <p>
          These pages are static and crawlable, with local watchlist actions layered on top
          in the browser.
        </p>
      </div>
      <a class="button" href="/rankings/">All rankings</a>
    </div>
    <div class="anime-grid">
      {trending.map((anime, index) => <AnimeCard anime={anime} rank={index + 1} compact />)}
    </div>
  </section>
</BaseLayout>
