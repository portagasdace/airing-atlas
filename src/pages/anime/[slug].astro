---
import BaseLayout from "@/layouts/BaseLayout.astro";
import AffiliatePanel from "@/components/AffiliatePanel.astro";
import AdSlot from "@/components/AdSlot.astro";
import { allAnime, canonicalPath, cleanText, dateTimeLabel, displayTitle, episodeLabel, formatNumber, genreIndex, recommendationsFor, scoreLabel, seasonLabel, titleCase } from "@/lib/anime";
import { manualEditorialFor, qualityWatchOrderFor } from "@/lib/manual-content";
import { isQualityNextEpisodeAnime } from "@/lib/quality";
import { animeLikeSlug, nextEpisodeSlug, relatedSearchIntents } from "@/lib/search-intents";
import { animeJsonLd, breadcrumbJsonLd } from "@/lib/seo";
import type { AnimeSummary } from "@/types/anime";

export function getStaticPaths() {
  return allAnime.map((anime) => ({
    params: { slug: anime.slug },
    props: { anime }
  }));
}

const { anime } = Astro.props as { anime: AnimeSummary };
const title = displayTitle(anime);
const cover = anime.coverImage?.extraLarge || anime.coverImage?.large || "/og-default.svg";
const manualEditorial = manualEditorialFor(anime.id);
const metaDescription = manualEditorial?.intro.slice(0, 155) || cleanText(anime.description, 155) || `Compare ${title} airing details, score, genres, recommendations, watch order links, and legal research links on Airing Atlas.`;
const recommendations = recommendationsFor(anime.id).slice(0, 4);
const guide = qualityWatchOrderFor(anime.id);
const tags = (anime.tags || []).slice(0, 8);
const officialLinks = (anime.externalLinks || []).filter((link) => link.url && link.site).slice(0, 5);
const studio = anime.studios?.[0]?.name;
const genreLinks = (anime.genres || []).map((genre) => ({
  name: genre,
  slug: genreIndex.items.find((item) => item.genre === genre)?.slug
}));
const searchIntents = relatedSearchIntents({ anime, recommendations, guide, genreLinks });
const structuredData = [
  breadcrumbJsonLd([
    { name: "Airing Atlas", path: "/" },
    { name: "Anime", path: "/discover/" },
    { name: title, path: `/anime/${anime.slug}/` }
  ]),
  animeJsonLd(anime, title, metaDescription, cover)
];
---

<BaseLayout
  title={title}
  description={metaDescription}
  canonical={canonicalPath(`/anime/${anime.slug}/`)}
  image={cover}
  structuredData={structuredData}
>
  <section class="detail-hero">
    <img class="detail-poster" src={cover} alt="" width="300" height="420" referrerpolicy="no-referrer" />
    <div class="detail-copy">
      <p class="eyebrow">{seasonLabel(anime)} · {anime.format || "Anime"}</p>
      <h1>{title}</h1>
      <p class="lede">{manualEditorial?.intro || cleanText(anime.description, 260)}</p>
      <div class="hero-actions">
        <button
          class="button primary"
          type="button"
          data-watchlist-toggle
          data-anime-id={anime.id}
          data-title={title}
          data-cover={cover}
          data-slug={anime.slug}
          data-next-airing={anime.nextAiringEpisode?.airingAt || ""}
        >
          Add
        </button>
        <label>
          <span class="sr-only">Watch status</span>
          <select
            data-watchlist-status
            data-anime-id={anime.id}
            data-title={title}
            data-cover={cover}
            data-slug={anime.slug}
            data-next-airing={anime.nextAiringEpisode?.airingAt || ""}
          >
            <option value="watching">watching</option>
            <option value="planned" selected>planned</option>
            <option value="completed">completed</option>
            <option value="dropped">dropped</option>
          </select>
        </label>
        <a class="button" href={`/similar/?anime=${anime.id}`} data-track-event="detail_open_similar" data-track-label={title}>Similar</a>
        <a class="button" href={`/anime-like/${animeLikeSlug(anime)}/`} data-track-event="detail_open_anime_like" data-track-label={title}>Anime like this</a>
        {isQualityNextEpisodeAnime(anime) && <a class="button" href={`/next-episode/${nextEpisodeSlug(anime)}/`} data-track-event="next_episode_detail_click" data-track-label={`${title} next episode`}>Next episode</a>}
        {guide && <a class="button" href={`/watch-order/${guide.slug}/`} data-track-event="detail_open_watch_order" data-track-label={guide.title}>Watch order</a>}
      </div>
      <div class="fact-strip">
        <div><span>Score</span><strong>{scoreLabel(anime)}</strong></div>
        <div><span>Episodes</span><strong>{episodeLabel(anime)}</strong></div>
        <div><span>Popularity</span><strong>{formatNumber(anime.popularity)}</strong></div>
        <div><span>Next</span><strong>{dateTimeLabel(anime.nextAiringEpisode?.airingAt)}</strong></div>
      </div>
      <div class="detail-meta">
        {studio && <span>Main studio: {studio}</span>}
        {anime.source && <span>Source: {titleCase(anime.source)}</span>}
        {anime.status && <span>Status: {titleCase(anime.status)}</span>}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="tag-row">
      {genreLinks.map((genre) => (
        genre.slug
          ? <a href={`/genres/${genre.slug}/`} data-track-event="detail_genre_click" data-track-label={genre.name}>{genre.name}</a>
          : <span>{genre.name}</span>
      ))}
      {tags.map((tag) => <span>{tag.name}</span>)}
    </div>
  </section>

  <section class="section">
    <div class="keyword-panel">
      <p class="eyebrow">Related search keywords</p>
      <h2>Search phrases around {title}</h2>
      <p>Useful long-tail routes for similar anime, release timing, genre discovery, and watch order research.</p>
      <div class="keyword-list">
        {searchIntents.map((item) => (
          <a href={item.href} data-track-event="keyword_click" data-track-label={item.label}>
            <span>{item.intent}</span>
            {item.label}
          </a>
        ))}
      </div>
    </div>
  </section>

  {recommendations.length > 0 && (
    <section class="section">
      <div class="section-header">
        <div>
          <p class="eyebrow">Similar anime</p>
          <h2>Watch next if you like {title}</h2>
          <p>Recommendations combine AniList user signals with shared genre, tag, format, studio, and score patterns.</p>
        </div>
        <a class="button" href={`/similar/?anime=${anime.id}`} data-track-event="detail_open_similar_section" data-track-label={title}>Open finder</a>
      </div>
      <div class="recommendation-grid">
        {recommendations.map((item) => (
          <article class="recommendation-card">
            <a class="result-poster" href={`/anime/${item.slug}/`}>
              <img src={item.coverImage || "/og-default.svg"} alt="" width="104" height="146" loading="lazy" referrerpolicy="no-referrer" />
            </a>
            <div>
              <p class="eyebrow">{item.source === "anilist" ? "AniList signal" : "Atlas match"}</p>
              <h3><a href={`/anime/${item.slug}/`}>{item.title}</a></h3>
              <p>{item.reason}</p>
              <div class="tag-row">
                {(item.signals || []).slice(0, 2).map((signal) => <span>{signal}</span>)}
              </div>
            </div>
          </article>
        ))}
      </div>
    </section>
  )}

  {guide && (
    <section class="section">
      <div class="editor-note">
        <p class="eyebrow">Franchise path</p>
        <h2>{guide.title}</h2>
        <p>{guide.description}</p>
        <a class="button small" href={`/watch-order/${guide.slug}/`}>Open watch order</a>
      </div>
    </section>
  )}

  {(manualEditorial || anime.editorialNote) && (
    <section class="section">
      <div class="editor-note">
        <p class="eyebrow">Atlas editor note</p>
        <p>{manualEditorial?.intro || anime.editorialNote}</p>
        {manualEditorial?.legalWatchingNote && <p>{manualEditorial.legalWatchingNote}</p>}
      </div>
    </section>
  )}

  <section class="section">
    <AdSlot />
    {officialLinks.length > 0 && (
      <div class="editor-note official-links">
        <p class="eyebrow">Official links</p>
        <div class="link-list">
          {officialLinks.map((link) => (
            <a href={link.url || "#"} rel="nofollow noopener" target="_blank" data-track-event="legal_link_click" data-track-label={`${title} ${link.site}`}>{link.site}</a>
          ))}
        </div>
      </div>
    )}
    <AffiliatePanel anime={anime} />
  </section>
</BaseLayout>
