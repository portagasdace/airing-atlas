---
import BaseLayout from "@/layouts/BaseLayout.astro";
import AdSlot from "@/components/AdSlot.astro";
import { allAnime, animeById, animeByIds, canonicalPath, cleanText, displayTitle, genreIndex, recommendationsFor, scoreLabel, seasonLabel, titleCase } from "@/lib/anime";
import { manualFeaturedAnimeIds, manualSimilarGuideFor, qualityWatchOrderFor } from "@/lib/manual-content";
import { animeLikeSlug, relatedSearchIntents } from "@/lib/search-intents";
import { breadcrumbJsonLd } from "@/lib/seo";
import type { AnimeRecommendation, AnimeSummary } from "@/types/anime";

type RecommendationCard = AnimeRecommendation & { format?: string | null; status?: string | null; seasonText?: string };

export function getStaticPaths() {
  const seen = new Set<string>();
  const blockedFormats = new Set(["MANGA", "NOVEL", "ONE_SHOT", "LIGHT_NOVEL"]);
  const curatedTargets = manualFeaturedAnimeIds.map((id) => animeById(id)).filter(Boolean) as AnimeSummary[];
  const automaticTargets = allAnime
    .filter((anime) => recommendationsFor(anime.id).length >= 3 && !blockedFormats.has(String(anime.format || "").toUpperCase()))
    .sort((a, b) => (b.popularity || 0) - (a.popularity || 0))
    .slice(0, 140);
  const targets = [...curatedTargets, ...automaticTargets].filter((anime, index, items) => items.findIndex((item) => item.id === anime.id) === index);

  return targets.flatMap((anime) => {
    const slug = animeLikeSlug(anime);
    if (!slug || seen.has(slug)) return [];
    seen.add(slug);
    return [{
      params: { slug },
      props: { anime }
    }];
  });
}

const { anime } = Astro.props as { anime: AnimeSummary };
const title = displayTitle(anime);
const manualGuide = manualSimilarGuideFor(anime.id);
const guide = qualityWatchOrderFor(anime.id);
const blockedRecommendationFormats = new Set(["MANGA", "NOVEL", "ONE_SHOT", "LIGHT_NOVEL"]);
const isAnimeMedia = (item?: AnimeSummary) => item ? !blockedRecommendationFormats.has(String(item.format || "").toUpperCase()) : true;
const direct = recommendationsFor(anime.id).filter((item) => isAnimeMedia(animeById(item.animeId)));
const fallback = allAnime
  .filter((candidate) => candidate.id !== anime.id && isAnimeMedia(candidate))
  .map((candidate) => ({
    candidate,
    sharedGenres: (anime.genres || []).filter((genre) => (candidate.genres || []).includes(genre)),
    sharedTags: (anime.tags || []).filter((tag) => tag.name && (candidate.tags || []).some((candidateTag) => candidateTag.name === tag.name))
  }))
  .filter((item) => item.sharedGenres.length || item.sharedTags.length >= 2)
  .sort((a, b) => {
    const signalDiff = (b.sharedGenres.length * 3 + b.sharedTags.length) - (a.sharedGenres.length * 3 + a.sharedTags.length);
    return signalDiff || (b.candidate.popularity || 0) - (a.candidate.popularity || 0);
  })
  .slice(0, 10)
  .map(({ candidate, sharedGenres, sharedTags }) => ({
    animeId: candidate.id,
    title: displayTitle(candidate),
    slug: candidate.slug,
    reason: sharedGenres.length
      ? `Shared genres: ${sharedGenres.slice(0, 3).join(", ")}`
      : `Shared tags: ${sharedTags.map((tag) => tag.name).filter(Boolean).slice(0, 3).join(", ")}`,
    signals: [...sharedGenres.slice(0, 2), ...sharedTags.map((tag) => tag.name).filter(Boolean).slice(0, 2)],
    source: "similarity" as const,
    coverImage: candidate.coverImage?.large || candidate.coverImage?.extraLarge || "",
    genres: candidate.genres,
    format: candidate.format,
    status: candidate.status,
    seasonText: seasonLabel(candidate)
  }));

const rawRecommendations = [...direct, ...fallback]
  .filter((item, index, items) => items.findIndex((candidate) => candidate.animeId === item.animeId) === index)
  .map((item) => {
    const full = animeById(item.animeId);
    return {
      ...item,
      title: full ? displayTitle(full) : item.title,
      slug: full?.slug || item.slug,
      coverImage: full?.coverImage?.large || full?.coverImage?.extraLarge || item.coverImage,
      genres: full?.genres || item.genres,
      format: full?.format || (item as RecommendationCard).format,
      status: full?.status || (item as RecommendationCard).status,
      seasonText: full ? seasonLabel(full) : (item as RecommendationCard).seasonText,
      reason: manualGuide?.recommendationNotes[item.animeId] || item.reason
    };
  }) as RecommendationCard[];

const recommendations = rawRecommendations
  .sort((a, b) => {
    if (manualGuide?.bestOverallPick === a.animeId) return -1;
    if (manualGuide?.bestOverallPick === b.animeId) return 1;
    return 0;
  })
  .slice(0, 10);

const genreLinks = (anime.genres || []).map((genre) => ({
  name: genre,
  slug: genreIndex.items.find((item) => item.genre === genre)?.slug
}));
const searchIntents = relatedSearchIntents({ anime, recommendations, guide, genreLinks });
const relatedGuides = manualGuide
  ? animeByIds(manualGuide.relatedGuideIds).map((item) => ({
    label: `Anime like ${displayTitle(item)}`,
    href: `/anime-like/${animeLikeSlug(item)}/`,
    intent: "Similar guide"
  }))
  : [];
const primaryGenres = (anime.genres || []).slice(0, 3).join(", ");
const canonical = `/anime-like/${animeLikeSlug(anime)}/`;
const description = manualGuide?.intro.slice(0, 155) || `Find anime like ${title}, with similar recommendations, shared genres${primaryGenres ? ` like ${primaryGenres}` : ""}, audience signals, and legal discovery links.`;
const bestOverall = recommendations.find((item) => item.animeId === manualGuide?.bestOverallPick) || recommendations[0];
const matchAngles = (manualGuide?.matchAngles || []).map((angle) => ({
  ...angle,
  anime: animeByIds(angle.animeIds)
}));
const structuredData: Record<string, unknown>[] = [
  breadcrumbJsonLd([
    { name: "Airing Atlas", path: "/" },
    { name: "Anime Like", path: "/anime-like/" },
    { name: `Anime like ${title}`, path: canonical }
  ]),
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: `Anime like ${title}`,
    description,
    url: canonicalPath(canonical),
    keywords: searchIntents.map((item) => item.label).join(", "),
    mainEntity: {
      "@type": "ItemList",
      itemListElement: recommendations.slice(0, 8).map((item, index) => ({
        "@type": "ListItem",
        position: index + 1,
        name: item.title,
        url: canonicalPath(`/anime/${item.slug}/`)
      }))
    }
  }
];
if (manualGuide?.faq.length) {
  structuredData.push({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: manualGuide.faq.map((item) => ({
      "@type": "Question",
      name: item.question,
      acceptedAnswer: {
        "@type": "Answer",
        text: item.answer
      }
    }))
  });
}
---

<BaseLayout
  title={`Anime like ${title}`}
  description={description}
  canonical={canonicalPath(canonical)}
  image={anime.coverImage?.extraLarge || anime.coverImage?.large || "/og-default.svg"}
  structuredData={structuredData}
>
  <section class="section">
    <div class="section-header">
      <div>
        <p class="eyebrow">Similarity guide</p>
        <h1>Anime like {title}</h1>
        <p>{manualGuide?.intro || `A crawlable recommendation page for fans searching for shows similar to ${title}. Matches are based on AniList recommendation signals, shared genres, tags, format, score, and audience popularity.`}</p>
      </div>
      <a class="button primary" href={`/similar/?anime=${anime.id}`} data-track-event="anime_like_open_tool" data-track-label={title}>Open finder</a>
    </div>
  </section>

  <section class="section">
    <div class="selected-anime">
      <img src={anime.coverImage?.large || anime.coverImage?.extraLarge || "/og-default.svg"} alt="" width="104" height="146" loading="lazy" referrerpolicy="no-referrer" />
      <div>
        <p class="eyebrow">Reference title</p>
        <h2><a href={`/anime/${anime.slug}/`}>{title}</a></h2>
        <p>{cleanText(anime.description || "", 240)}</p>
        <div class="tag-row">
          {(anime.genres || []).slice(0, 5).map((genre) => <span>{genre}</span>)}
          <span>{scoreLabel(anime)}</span>
          {anime.format && <span>{titleCase(anime.format)}</span>}
        </div>
      </div>
    </div>
  </section>

  {manualGuide && (
    <section class="section split-feature">
      <div class="editor-note">
        <p class="eyebrow">Why fans search this</p>
        <h2>Why fans look for anime like {title}</h2>
        <p>{manualGuide.whySimilar}</p>
      </div>
      {bestOverall && (
        <div class="editor-note">
          <p class="eyebrow">Closest overall pick</p>
          <h2>{bestOverall.title}</h2>
          <p>{bestOverall.reason}</p>
          <a class="button small" href={`/anime/${bestOverall.slug}/`} data-track-event="anime_like_result_click" data-track-label={bestOverall.title}>Open anime</a>
        </div>
      )}
    </section>
  )}

  {matchAngles.length > 0 && (
    <section class="section guide-grid">
      {matchAngles.map((angle) => (
        <article class="guide-card">
          <p class="eyebrow">Best for</p>
          <h2>{angle.label}</h2>
          <p>{angle.description}</p>
          <div class="link-stack">
            {angle.anime.map((item) => (
              <a href={`/anime/${item.slug}/`} data-track-event="anime_like_result_click" data-track-label={displayTitle(item)}>{displayTitle(item)}</a>
            ))}
          </div>
        </article>
      ))}
    </section>
  )}

  <section class="section">
    <div class="section-header">
      <div>
        <p class="eyebrow">Recommended matches</p>
        <h2>Shows similar to {title}</h2>
        <p>Each card includes the strongest match reason, so the page reads like a useful guide rather than a loose keyword list.</p>
      </div>
    </div>
    <div class="recommendation-grid">
      {recommendations.slice(0, 8).map((item) => (
        <article class="recommendation-card">
          <a class="result-poster" href={`/anime/${item.slug}/`} data-track-event="anime_like_result_click" data-track-label={item.title}>
            <img src={item.coverImage || "/og-default.svg"} alt="" width="104" height="146" loading="lazy" referrerpolicy="no-referrer" />
          </a>
          <div>
            <p class="eyebrow">{item.source === "anilist" ? "AniList signal" : "Atlas match"}</p>
            <h3><a href={`/anime/${item.slug}/`} data-track-event="anime_like_result_click" data-track-label={item.title}>{item.title}</a></h3>
            <p>{item.reason}</p>
            <div class="tag-row">
              {(item.signals || []).slice(0, 3).map((signal) => <span>{signal}</span>)}
              {item.format && <span>{titleCase(item.format)}</span>}
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="keyword-panel">
      <p class="eyebrow">Related guides</p>
      <h2>More useful routes from {title}</h2>
      <p>These are readable guide paths around similar anime, release timing, genre discovery, and franchise order.</p>
      <div class="keyword-list">
        {[...relatedGuides, ...searchIntents].slice(0, 10).map((item) => (
          <a href={item.href} data-track-event="related_guide_click" data-track-label={item.label}>
            <span>{item.intent}</span>
            {item.label}
          </a>
        ))}
      </div>
    </div>
  </section>

  {manualGuide?.faq.length && (
    <section class="section">
      <div class="keyword-panel">
        <p class="eyebrow">FAQ</p>
        <h2>{title} recommendation questions</h2>
        <div class="faq-grid">
          {manualGuide.faq.map((item) => (
            <article>
              <h3>{item.question}</h3>
              <p>{item.answer}</p>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="section">
    <AdSlot />
  </section>
</BaseLayout>
